{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "paths": {
      "uca/types": ["./types/index.ts"],
      "uca/roles": ["./roles/index.ts"],
      "uca/ui": ["./ui/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
